# Cloudflare Pages security + caching headers
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  # Permissions-Policy: scope mic access to the ConvAI widget iframe
  # (elevenlabs.io). Wildcard subdomains aren't valid in this header per the
  # W3C draft — only concrete origins. If the widget ever moves to a
  # subdomain, extend the list with the exact host.
  Permissions-Policy: camera=(), microphone=("https://elevenlabs.io"), geolocation=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  X-Robots-Tag: index, follow
  # CSP — script-src + style-src still permit 'unsafe-inline' because the
  # console runs babel-standalone in-browser to transpile JSX. Migration
  # to a pre-built bundle that drops both 'unsafe-inline' and the CDN
  # script-src is tracked as a separate hardening item; doing it requires
  # adding a build step (Vite/esbuild) and self-hosting React/Babel.
  # connect-src + media-src narrowed from `https: wss:` (any origin) to
  # explicit ElevenLabs hosts — the console only talks to itself + the
  # Convai widget. Tightens the post-XSS exfiltration surface.
  # report-uri: browsers POST a JSON violation report to /api/csp-report
  # (Cloudflare Pages Function) when a directive blocks a load. Logged
  # via wrangler tail / dashboard so misconfigurations surface
  # immediately instead of as user complaints.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://elevenlabs.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://elevenlabs.io https://*.elevenlabs.io wss://elevenlabs.io wss://*.elevenlabs.io; media-src 'self' blob: https://elevenlabs.io https://*.elevenlabs.io; worker-src 'self' blob:; frame-src https://elevenlabs.io https://*.elevenlabs.io; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; report-uri /api/csp-report

# Long-cache the immutable token assets
/tokens/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache the synthetic fixtures (DEMO_MODE data is stable per-deploy)
/fixtures/*
  Cache-Control: public, max-age=3600

# Don't cache HTML — let users see deploys immediately
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap / robots — short cache so updates propagate
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600
