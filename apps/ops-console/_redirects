# Cloudflare Pages redirects
# https://developers.cloudflare.com/pages/configuration/redirects/

# Friendly alias for the legacy `/api/eval-runs` URL the UI used briefly
# before the canonical `/api/eval/runs` route landed in server.js.
/api/eval-runs    /fixtures/eval-runs.json    302

# Redirect bare `/api/*` calls in DEMO_MODE to the fixture equivalent.
# (The DEMO_MODE shim in each HTML page already handles this client-side,
# but a 404 fallback to fixtures keeps non-shim consumers from breaking.)
/api/*            /fixtures/:splat.json       302
