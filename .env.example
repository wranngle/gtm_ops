# gtm_ops - Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env with real values to version control.
#
# Keep this file in lockstep with the process.env.* surface in code
# (grep -rhoE "process\.env\.[A-Z_][A-Z0-9_]*" lib src server.ts scripts
# functions). Vars marked "reserved" have no consumer yet — everything else
# is runtime-read. Graceful-degradation notes live next to each var.

# ===================================
# LLM Provider API Keys
# ===================================

# Google Gemini (required for unstructured input processing in the presales
# extraction pipeline; optional when using structured JSON input).
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (optional fallback for LLM operations).
# https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI (reserved for Phase 2 unified presales runtime; not yet referenced
# by current gtm_ops code — uncomment when consumers land).
# OPENAI_API_KEY=

# Anthropic (reserved for Phase 2 unified presales runtime; not yet referenced
# by current gtm_ops code — uncomment when consumers land).
# ANTHROPIC_API_KEY=

# ===================================
# Enrichment / Research API Keys
# ===================================

# People Data Labs (B2B contact enrichment).
PDL_API_KEY=

# Enrich.so (alternative enrichment provider).
ENRICH_SO_API_KEY=

# AbstractAPI (email validation, phone validation, IP geolocation).
ABSTRACT_API_KEY=

# Exa.ai (semantic web research). Read by lib/research-tools.ts via
# lib/proactive-research.ts: when set, retrieved results are injected into the
# integration-research prompt as primary evidence; unset is a silent no-op.
EXA_API_KEY=

# Tavily (web search / research). Same wiring as EXA_API_KEY.
TAVILY_API_KEY=

# ===================================
# Server Configuration
# ===================================

# Port for the Express runtime (server.ts) and ops-console UI.
PORT=3000

# Bind address for the Express runtime. Defaults to 127.0.0.1 (loopback only);
# set 0.0.0.0 to expose on all interfaces (containers, LAN testing).
# HOST=127.0.0.1

# Node environment ("development" | "production"). Affects logging verbosity
# and Puppeteer sandbox defaults.
NODE_ENV=development

# Log level ("trace" | "debug" | "info" | "warn" | "error").
LOG_LEVEL=info

# Demo mode. Read by lib/pdf-generator.ts (renders the demo watermark) and by
# branding flows that fall back to in-repo fixtures instead of the DB.
# DEMO_MODE=true

# ===================================
# CORS / Webhook Security
# ===================================

# Comma-separated CORS origin allowlist for the API.
ALLOWED_ORIGINS=

# Shared secret sent as X-Webhook-Secret on outbound n8n webhook calls.
# When unset, the runtime warns loudly and proceeds without the auth header
# (graceful no-op suitable for dev/test). Set this in production.
N8N_WEBHOOK_SECRET=

# n8n enrichment webhook URL (optional override). When unset, server.ts falls
# back to https://n8n.wranngle.com/webhook/lead-enrichment.
N8N_ENRICHMENT_WEBHOOK_URL=

# n8n leads-intake webhook (Cloudflare Pages env var, NOT read by the Express
# runtime): functions/api/leads.ts forwards landing-page leads there when set,
# and no-ops gracefully when unset. Configure via
# `wrangler pages secret put N8N_LEADS_WEBHOOK --project-name=gtm-ops`
# or the Pages dashboard — listed here only so the var is documented.
# N8N_LEADS_WEBHOOK=

# Override path to the technical-research library consumed by the
# presales pipeline's enrichment stage. Defaults to bundled
# context/generated-research/ inside this repo.
# N8N_RESEARCH_LIBRARY_PATH=./context/generated-research

# Branding DB path (reserved for Phase 2 unified runtime; comment out for
# DEMO_MODE / in-repo fixture serving).
# BRANDING_DB_PATH=./data/branding.db

# ===================================
# Producer / Branding (report defaults)
# ===================================

PRODUCER_NAME=
PRODUCER_EMAIL=
PRODUCER_DOMAIN=
LOGO_URI=
CTA_BOOK_CALL_LINK=
APPROVE_LINK_TEMPLATE=

# ===================================
# Pipeline Defaults / Validation
# ===================================

# Default platform target for generated artifacts (e.g., "web", "ios", "android").
DEFAULT_PLATFORM=

# Default validity window for generated quotes (days).
DEFAULT_VALIDITY_DAYS=

# Validation mode ("strict" | "permissive" | "off"). Read by lib/utils/validation.ts.
VALIDATION_MODE=

# Toggle strict input validation. Read by lib/schema_validation.{js,ts}.
STRICT_VALIDATION=false

# ===================================
# Database
# ===================================

# Database connection string (e.g., postgres://...).
DATABASE_URL=

# ===================================
# PDF Rendering (PyMuPDF + Puppeteer)
# ===================================

# Python interpreter used for PyMuPDF proposal rendering. Defaults to
# .venv/bin/python; set when pymupdf lives in a different interpreter.
# See docs/references/pdf-generation.md.
# PYMUPDF_PYTHON=

# Disable Puppeteer's Chromium sandbox. Required when running in Docker /
# containerized environments. Leave unset (or "false") on local dev.
# PUPPETEER_NO_SANDBOX=true

# Override the Chromium executable Puppeteer launches.
# PUPPETEER_EXECUTABLE_PATH=

# ===================================
# Tests
# ===================================

# Override placeholder secret used by webhook integration tests.
TEST_API_KEY=

# CI flag (auto-set by most CI runners; do not set manually). Read by
# playwright.config.ts to harden retries/workers in CI.
# CI=

# ===================================
# Notes
# ===================================
# - For structured JSON input, GEMINI_API_KEY is not required.
# - The .env file is loaded by the application at startup
#   (see "bun --env-file=.env" usage in package.json scripts).
# - In production, prefer secrets management (Docker / K8s secrets) over .env.
# - Rotate API keys regularly and monitor usage.
