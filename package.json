{
  "name": "gtm_ops",
  "version": "1.0.0",
  "description": "Voice-AI-led GTM motion runtime: presales pipeline (LLM extraction -> branded PDF -> CRM) + ops-console UI + sample n8n workflows + design tokens. One repo, one runnable thing.",
  "type": "module",
  "main": "server.ts",
  "bin": {
    "wranngle": "./cli.ts"
  },
  "scripts": {
    "start": "bun --env-file=.env server.ts",
    "generate": "bun --env-file=.env cli.ts generate",
    "verify": "bun --env-file=.env scripts/verify-output.ts",
    "audit:verify": "bun scripts/audit-verify.mjs",
    "dev": "bun --env-file=.env --watch server.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "tsc -p functions/tsconfig.json",
    "typecheck:console": "tsc -p apps/ops-console/tsconfig.json",
    "lint": "xo",
    "lint:fix": "xo --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:p0": "vitest run -t '\\[P0\\]'",
    "test:p1": "vitest run -t '\\[P0\\]|\\[P1\\]'",
    "test:ui": "vitest --ui --open",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:console": "playwright test -c playwright.console.config.ts",
    "test:console:ui": "playwright test -c playwright.console.config.ts --ui",
    "test:all": "vitest run && playwright test && playwright test -c playwright.console.config.ts",
    "deploy": "wrangler pages deploy apps/ops-console --project-name=gtm-ops",
    "deploy:preview": "wrangler pages deploy apps/ops-console --project-name=gtm-ops --branch=preview",
    "pages:dev": "wrangler pages dev apps/ops-console",
    "eval:import": "bun --env-file=.env cli.ts eval:import",
    "eval:quick": "bun --env-file=.env cli.ts eval:batch --limit 5",
    "eval:full": "bun --env-file=.env cli.ts eval:batch",
    "eval:report": "bun --env-file=.env cli.ts eval:report --verbose",
    "eval:harness": "test -f ../voice_ai_agent_evals/scripts/run-gtm-ops-adapter.ts || { echo 'eval:harness needs wranngle/voice_ai_agent_evals cloned as a sibling of this repo'; exit 1; }; bun ../voice_ai_agent_evals/scripts/run-gtm-ops-adapter.ts --root ."
  },
  "keywords": [
    "gtm",
    "presales",
    "voice-agents",
    "automation",
    "n8n",
    "proposal-generator",
    "design-tokens"
  ],
  "author": "Wranngle Systems LLC",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "ajv": "8.20.0",
    "ajv-formats": "^3.0.1",
    "arktype": "2.2.0",
    "dotenv": "^16.3.1",
    "eventsource": "^4.1.0",
    "express": "^4.18.2",
    "mustache": "^4.2.0",
    "sql.js": "^1.13.0",
    "sqlite3": "^6.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@cloudflare/workers-types": "4.20260528.1",
    "@faker-js/faker": "^10.2.0",
    "@playwright/test": "^1.57.0",
    "@types/express": "^4.17.21",
    "@types/mustache": "^4.2.5",
    "@types/node": "^25.7.0",
    "@types/react": "18",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.18",
    "bun-types": "1.3.14",
    "eslint-config-xo-typescript": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "6.0.3",
    "vitest": "^4.0.16",
    "xo": "2.0.2"
  },
  "overrides": {
    "ip-address": "10.1.1",
    "fast-uri": "^3.1.2"
  }
}
