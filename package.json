{
  "name": "gtm_ops",
  "version": "1.0.0",
  "description": "Voice-AI-led GTM motion runtime: presales pipeline (LLM extraction -> branded PDF -> CRM) + ops-console UI + sample n8n workflows + design tokens. One repo, one runnable thing.",
  "type": "module",
  "main": "server.js",
  "bin": {
    "wranngle": "./cli.js"
  },
  "scripts": {
    "start": "bun --env-file=.env server.js",
    "generate": "bun --env-file=.env cli.js generate",
    "verify": "bun --env-file=.env scripts/verify_output.js",
    "dev": "bun --env-file=.env --watch server.js",
    "typecheck": "tsc --noEmit",
    "lint": "xo",
    "lint:fix": "xo --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:p0": "vitest run -t '\\[P0\\]'",
    "test:p1": "vitest run -t '\\[P0\\]|\\[P1\\]'",
    "test:ui": "vitest --ui --open",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:console": "playwright test -c playwright.console.config.ts",
    "test:console:ui": "playwright test -c playwright.console.config.ts --ui",
    "test:all": "vitest run && playwright test && playwright test -c playwright.console.config.ts",
    "deploy": "wrangler pages deploy apps/ops-console --project-name=gtm-ops",
    "deploy:preview": "wrangler pages deploy apps/ops-console --project-name=gtm-ops --branch=preview",
    "pages:dev": "wrangler pages dev apps/ops-console",
    "eval:import": "bun --env-file=.env cli.js eval:import",
    "eval:quick": "bun --env-file=.env cli.js eval:batch --limit 5",
    "eval:full": "bun --env-file=.env cli.js eval:batch",
    "eval:report": "bun --env-file=.env cli.js eval:report --verbose",
    "eval:harness": "bun ../voice_ai_agent_evals/scripts/run-gtm-ops-adapter.ts --root ."
  },
  "keywords": [
    "gtm",
    "presales",
    "voice-agents",
    "automation",
    "n8n",
    "proposal-generator",
    "design-tokens"
  ],
  "author": "Wranngle Systems LLC",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "cors": "2.8.5",
    "dotenv": "^16.3.1",
    "eventsource": "^2.0.2",
    "express": "^4.18.2",
    "express-rate-limit": "8.2.1",
    "mustache": "^4.2.0",
    "open": "^10.0.0",
    "puppeteer": "^21.6.1",
    "sql.js": "^1.13.0",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@faker-js/faker": "^10.2.0",
    "@playwright/test": "^1.57.0",
    "@types/express": "^4.17.21",
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.18",
    "arktype": "2.2.0",
    "bun-types": "1.3.13",
    "eslint-config-xo-typescript": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.16",
    "xo": "1.2.3"
  }
}
