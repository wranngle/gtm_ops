# gtm_ops .gitignore — keep transient agent / build / log artifacts out of git.

# Secrets and OS noise
.env
.env.*
.DS_Store
*.swp
*.tmp
*.log

# Generic build / install artifacts
node_modules/
__pycache__/
.venv/
target/
dist/
build/

# Project-local runtime
.assessment.cache
logs/
old/
temp/

# CSV-validator demo runtime state
examples/csv-validator/queue/in_progress/*
!examples/csv-validator/queue/in_progress/.gitkeep
examples/csv-validator/queue/done/*
!examples/csv-validator/queue/done/.gitkeep
examples/csv-validator/queue/human_review/*
!examples/csv-validator/queue/human_review/.gitkeep
examples/csv-validator/workspaces/*
!examples/csv-validator/workspaces/.gitkeep

# Claude Code agent worktrees (transient, not for git)
.claude/worktrees/
.claude/*.lock

# Bun
.bun/
bun.lockb

# TypeScript incremental builds
**/*.tsbuildinfo

# Python build / test caches
**/*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage/
htmlcov/
pip-wheel-metadata/

# Erlang crash dumps (legacy, never re-add)
erl_crash.dump
**/erl_crash.dump

# OpenSpec working state (proposals churn — keep specs/ only)
openspec/changes/

# Playwright MCP runtime artifacts (transient agent snapshots)
.playwright-mcp/

# Demo render artifacts (regenerate via scripts/hero.sh)
demo/cassette.gif
demo/hero.gif
demo/hero.webp

# Windows alternate-data-stream metadata that comes through WSL copies
**/*:Zone.Identifier

# === Spec 006 §6.7 baseline (post-unification carry-over from unified-presales-report) ===
# SQLite DBs (branding, evaluation, presales, webhooks, audit, gdpr_test_*, admin_test_*, etc.)
*.db
*.sqlite
*.sqlite3

# Customer-data dirs (real PDFs, GDPR exports, lead inputs — NEVER track)
input/
output/
output_test/
exports/
_archive/

# n8n / eval test runtime
test-results/
_bmad-output/

# Symphony was relocated to ~/.dotfiles/; ignore any accidental re-creation
.symphony/
