# Fallback gitignore (offline or unknown language)
.env
.env.*
*.log
.DS_Store
*.swp
*.tmp
node_modules/
__pycache__/
.venv/
target/
dist/
build/

# Project-local
.env
.env.*
.assessment.cache
logs/*.jsonl
!logs/.gitkeep
.symphony/logs/*.jsonl
!.symphony/logs/.gitkeep
.symphony/workspaces/*
!.symphony/workspaces/.gitkeep
.symphony/runtime/*
!.symphony/runtime/.gitkeep

# Claude Code agent worktrees (transient, not for git)
.claude/worktrees/

# Elixir / Mix
tools/symphony-elixir/_build/
tools/symphony-elixir/deps/
tools/symphony-elixir/.elixir_ls/
erl_crash.dump
**/erl_crash.dump
