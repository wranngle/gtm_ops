# gtm_ops .gitignore — keep transient agent / build / log artifacts out of git.

# Secrets and OS noise
.env
.env.*
.DS_Store
*.swp
*.tmp
*.log

# Generic build / install artifacts
node_modules/
__pycache__/
.venv/
target/
dist/
build/

# Project-local runtime
.assessment.cache
.artifacts/
logs/
!apps/ops-console/fixtures/logs/
.agent-runs/
old/
temp/

# CSV-validator demo runtime state
examples/csv-validator/queue/in_progress/*
!examples/csv-validator/queue/in_progress/.gitkeep
examples/csv-validator/queue/done/*
!examples/csv-validator/queue/done/.gitkeep
examples/csv-validator/queue/human_review/*
!examples/csv-validator/queue/human_review/.gitkeep
examples/csv-validator/workspaces/*
!examples/csv-validator/workspaces/.gitkeep

# Claude Code / Gemini operator-local (keep .claude/commands/ + .gemini/commands/ committed; ignore everything else)
.claude/local/
.claude/worktrees/
.claude/mcp.json
.claude/.env
.claude/settings.json
.claude/scheduled_tasks*
.claude/*.lock
.claude/logs/
.gemini/local/
.gemini/settings.json
.bmad-output/
# Husky auto-managed (we use lefthook now — lefthook.yml is committed)
.husky/_/

# Bun
.bun/
bun.lockb
# npm/pnpm/yarn lockfiles — bun.lock is the only lockfile we commit
package-lock.json
pnpm-lock.yaml
yarn.lock

# TypeScript incremental builds
**/*.tsbuildinfo
# tsc declaration sourcemaps (stale build outputs; .d.ts hand-maintained)
**/*.d.ts.map

# Python build / test caches
**/*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage/
htmlcov/
pip-wheel-metadata/

# Erlang crash dumps (legacy, never re-add)
erl_crash.dump
**/erl_crash.dump

# OpenSpec working state (proposals churn — keep specs/ only)
openspec/changes/

# Playwright MCP runtime artifacts (transient agent snapshots)
.playwright-mcp/

# Cloudflare Wrangler / Pages local dev runtime cache
.wrangler/

# SQLite WAL/SHM/journal sidecars from test runtime (DBs already covered by *.db)
*.db-journal
*.sqlite-journal
*.db-wal
*.db-shm

# Demo render artifacts (regenerate via scripts/hero.sh)
demo/cassette.gif
demo/hero.gif
demo/hero.webp

# Windows alternate-data-stream metadata that comes through WSL copies
**/*:Zone.Identifier

# === Spec 006 §6.7 baseline (post-unification carry-over from unified-presales-report) ===
# SQLite DBs (branding, evaluation, presales, webhooks, audit, gdpr_test_*, admin_test_*, etc.)
*.db
*.sqlite
*.sqlite3

# Customer-data dirs (real PDFs, GDPR exports, lead inputs — NEVER track)
input/
output/
output_test/
exports/
_archive/

# n8n / eval test runtime
test-results/
test-results-console/
playwright-report/
playwright-console-report/
_bmad-output/

# Symphony was relocated to ~/.dotfiles/; ignore any accidental re-creation
.symphony/
logs/self-audit.log

# Codex / cynical-loop debug snapshots (transient — used by the loop scripts)
.codex-*.png
screenshot-*.jpg
scripts/cynical-ui-repair-loop.sh

# >>> dotfiles-managed gitignore (do not edit between markers) >>>
# Generated by .dotfiles.sh — edits between markers are overwritten on next deploy.
# Hand-edit OUTSIDE these markers for project-specific rules.
# Refresh language template: DOTFILES_GITIGNORE_REFRESH=1 ./.dotfiles.sh

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Secrets
.env
.env.*
!.env.example
!.env.template
*.pem
*.key

# Agent / AI scratch
.claude/
.codex/
.gemini/
.symphony/workspaces/
.assessment.cache

# Crash dumps & cores
*.dump
*.core
core.*
*.heapsnapshot
hs_err_pid*.log
erl_crash.dump

# Logs
logs/*
!logs/.gitkeep
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Generic build/cache/scratch
.cache/
tmp/
temp/
old/*
!old/.gitkeep

# --- Node (github/gitignore) ---
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.*
!.env.example

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist
.output

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and not Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# vuepress v2.x temp directory
.temp

# Sveltekit cache directory
.svelte-kit/

# vitepress build output
**/.vitepress/dist

# vitepress cache directory
**/.vitepress/cache

# Docusaurus cache and generated files
.docusaurus

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Firebase cache directory
.firebase/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# pnpm
.pnpm-store

# yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/
# <<< dotfiles-managed gitignore <<<
