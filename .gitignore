# wranngle-gtm-engine .gitignore — keep transient agent / build / log artifacts out of git.

# Secrets and OS noise
.env
.env.*
.DS_Store
*.swp
*.tmp
*.log

# Generic build / install artifacts
node_modules/
__pycache__/
.venv/
target/
dist/
build/

# Project-local runtime
.assessment.cache
logs/*.jsonl
!logs/.gitkeep

# Symphony orchestrator runtime (workspaces, logs, in-memory state snapshots)
.symphony/logs/*.jsonl
!.symphony/logs/.gitkeep
.symphony/workspaces/*
!.symphony/workspaces/.gitkeep
.symphony/runtime/*
!.symphony/runtime/.gitkeep

# CSV-validator demo runtime state
examples/csv-validator/queue/in_progress/*
!examples/csv-validator/queue/in_progress/.gitkeep
examples/csv-validator/queue/done/*
!examples/csv-validator/queue/done/.gitkeep
examples/csv-validator/queue/human_review/*
!examples/csv-validator/queue/human_review/.gitkeep
examples/csv-validator/workspaces/*
!examples/csv-validator/workspaces/.gitkeep

# Claude Code agent worktrees (transient, not for git)
.claude/worktrees/
.claude/*.lock

# Bun
.bun/
bun.lockb

# TypeScript incremental builds
**/*.tsbuildinfo

# Python build / test caches
**/*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage/
htmlcov/
pip-wheel-metadata/

# Elixir / Mix
tools/symphony-elixir/_build/
tools/symphony-elixir/deps/
tools/symphony-elixir/.elixir_ls/
tools/symphony-elixir/bin/
tools/symphony-elixir/.symphony/
erl_crash.dump
**/erl_crash.dump

# Playwright MCP runtime artifacts (transient agent snapshots)
.playwright-mcp/

# Edge MCP smoke artifacts (screenshots, dom dumps)
tools/edge-mcp/smoke/out/

# Local observability volume mounts and tail offsets
tools/observability/.data/
tools/observability/vector-data/

# Demo render artifacts (regenerate via scripts/hero.sh)
demo/cassette.gif
demo/hero.gif
demo/hero.webp

# Windows alternate-data-stream metadata that comes through WSL copies
**/*:Zone.Identifier
