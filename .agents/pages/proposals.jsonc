{
  "route": "console/?route=proposals",
  "purpose": "Review proposal packets, inspect PDF/source/audit artifacts, track blockers, and re-send buyer packets only after the operator sees the gate state.",
  "primaryUsers": ["operator", "reviewer"],
  "regions": [
    {
      "name": "review queue controls",
      "intent": "Keep All/Open filtering and Generate handoff available without turning the page into a hero or overview dashboard."
