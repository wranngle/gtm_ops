{
  "_comment": "mcp.example.json — synthetic placeholder for the gitignored mcp.json. Copy to mcp.json and populate real MCP endpoints + auth. The real file is gitignored because it contains tokens for upstream MCP servers (n8n cloud, ElevenLabs, etc.).",
  "mcpServers": {
    "presales-research": {
      "command": "npx",
      "args": ["-y", "@example/presales-research-mcp"],
      "env": {
        "RESEARCH_API_KEY": "your-research-api-key-here"
      }
    },
    "n8n-mcp": {
      "command": "npx",
      "args": ["-y", "@example/n8n-mcp-server"],
      "env": {
        "N8N_API_URL": "https://n8n.example.com/api/v1",
        "N8N_API_KEY": "your-n8n-api-key-here"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./output", "./input"],
      "env": {}
    }
  }
}
